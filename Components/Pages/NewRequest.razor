@page "/new-request"
@rendermode InteractiveServer
@attribute [Authorize]
@inject NavigationManager NavigationManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Новая заявка</PageTitle>
<div class="form-title">
	<h1>НОВАЯ ЗАЯВКА</h1>
</div>
<article class="content px-4">
	<EditForm FormName="CreateRequest" Model="request" OnValidSubmit="HandleSubmit">
		<DataAnnotationsValidator />
		<div class="form-group">
			<div class="form">
				<div class="input-container">
					<span class="icon"><i class="fa fa-user" aria-hidden="true"></i></span>
					<InputText @bind-Value="request.Full_name" type="text" placeholder="ФИО сотрудника" MaxLength="100" />
				</div>
				<ValidationMessage For="@(() => request.Full_name)" class="error-message" />
			</div>
			<div class="form">
				<div class="input-container">
					<span class="icon"><i class="fa fa-phone" aria-hidden="true"></i></span>
					<InputText @bind-Value="request.Phone" type="text" placeholder="Номер телефона" MaxLength="20" />
				</div>
				<ValidationMessage For="@(() => request.Phone)" class="error-message" />
			</div>
			<div class="form">
				<div class="input-container">
					<span class="icon"><i class="fa fa-map-marker" aria-hidden="true"></i></span>
					<InputText @bind-Value="request.Address" type="text" placeholder="Адрес офиса" MaxLength="200" />
				</div>
				<ValidationMessage For="@(() => request.Address)" class="error-message" />
			</div>
			<div class="form">
				<div class="input-container">
					<span class="icon"><i class="fa fa-building" aria-hidden="true"></i></span>
					<InputText @bind-Value="request.Cabinets" type="text" placeholder="Кабинеты" MaxLength="200" />
				</div>
				<ValidationMessage For="@(() => request.Cabinets)" class="error-message" />
			</div>
			<p>Выберите необходимые услуги</p>
			<div form>
				<div class="checkboxes-form">
					<fieldset class="checkboxes">
						@foreach (var service in allServices)
						{
							<label class="label-checkbox">
								<input value="@service.Id" type="checkbox" @onchange="e => ToggleService(service.Id, (bool)e.Value!)" />
								@service.Name
							</label>
						}
					</fieldset>
				</div>
				<ValidationMessage For="@(() => request.Services)" class="error-message" />
			</div>
			<p>Выберите дату и время</p>
			<div class="form">
				<div class="input-datetime">
					<InputDate @bind-Value="request.Request_date" min="@DateTime.Today.ToString("yyyy-MM-dd")" ParsingErrorMessage="Выберите дату уборки." />
					<InputDate Type="InputDateType.Time" @bind-Value="request.Request_time" min="08:00" max="20:00" />
				</div>
				<ValidationMessage For="@(() => request.Request_date)" class="error-message" />
				<ValidationMessage For="@(() => request.Request_time)" class="error-message" />
			</div>
			<InputTextArea @bind-Value="request.Comment" placeholder="Комментарий" rows="4" MaxLength="300" />
			<button id="send-request" type="submit">Создать заявку</button>
		</div>
	</EditForm>
</article>



@code {
	private Request request = new();
	private List<Service> allServices = new();
	private ApplicationUser? currentUser;

	protected override async Task OnInitializedAsync()
	{
		allServices = await DbContext.Services.ToListAsync();

		var authState = await AuthStateProvider.GetAuthenticationStateAsync();
		var user = authState.User;

		if (user?.Identity?.IsAuthenticated != true)
		{
			NavigationManager.NavigateTo("Account/Login");
			return;
		}
		;

		currentUser = await UserManager.GetUserAsync(user);

		if (currentUser is null)
			return;

		request.UserId = currentUser.Id;
	}

	private void ToggleService(int serviceId, bool isSelected)
	{
		var service = allServices.Find(s => s.Id == serviceId);
		if (service != null)
		{
			if (isSelected)
				request.Services.Add(service);
			else
				request.Services.Remove(service);
		}
	}

	private async Task HandleSubmit()
	{
		DbContext.Requests.Add(request);
		await DbContext.SaveChangesAsync();
		NavigationManager.NavigateTo("/my-requests");
	}
}